rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Seul le compte de l'auteur (connexion Google) peut publier et moderer.
    function estAdmin() {
      return request.auth != null
        && request.auth.token.email == 'nominesnow@gmail.com'
        && request.auth.token.firebase.sign_in_provider == 'google.com';
    }
    // Un membre suspendu (fiche dans /banned) ne peut plus rien ecrire.
    function estSuspendu(uid) {
      return exists(/databases/$(database)/documents/banned/$(uid));
    }

    // Grilles publiees : lisibles par tout joueur connecte, modifiables par l'auteur seul.
    match /puzzles/{puzzleId} {
      allow read: if request.auth != null;
      allow write: if estAdmin();
    }

    // Donnees propres a chaque joueur (progression, resultats, profil, serie).
    // Lues et ecrites par le joueur lui-meme (sauf s'il est suspendu) ; lues et
    // moderees par l'auteur (admin) sur n'importe quel compte.
    match /users/{uid}/{document=**} {
      allow read: if request.auth != null && (request.auth.uid == uid || estAdmin());
      allow write: if estAdmin()
        || (request.auth != null && request.auth.uid == uid && !estSuspendu(uid));
    }

    // Classement : chaque joueur publie sa propre fiche (pseudo, XP totale et par
    // mois). Lisible par tout joueur connecte, ecrite par le joueur (fiche validee,
    // s'il n'est pas suspendu) ou par l'auteur (moderation : correction, retrait).
    match /leaderboard/{uid} {
      allow read: if request.auth != null;
      allow write: if estAdmin()
        || (request.auth != null
            && request.auth.uid == uid
            && !estSuspendu(uid)
            && request.resource.data.pseudo is string
            && request.resource.data.pseudo.size() <= 40
            && request.resource.data.total is number
            && request.resource.data.total >= 0);
    }

    // Membres suspendus : chacun peut lire son propre statut (pour afficher
    // « compte suspendu »), l'auteur seul ecrit (suspendre / reactiver).
    match /banned/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || estAdmin());
      allow write: if estAdmin();
    }

    // Journal de moderation : ecrit et lu par l'auteur seul, et immuable
    // (aucune modification ni suppression, pour garder une trace fiable).
    match /moderation/{logId} {
      allow read: if estAdmin();
      allow create: if estAdmin();
      allow update, delete: if false;
    }

    // Premier a terminer la grille d'une date : un verrou « premier arrive »
    // (badge « Aux aguets »). Chaque joueur connecte non suspendu peut tenter de
    // le poser sur sa propre fiche ; une fois pose il est fige.
    match /premiers/{date} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && !estSuspendu(request.auth.uid);
      allow update, delete: if false;
    }
  }
}
